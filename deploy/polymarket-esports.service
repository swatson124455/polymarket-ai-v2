[Unit]
# SPLINTER (eb/main): EB runs from /opt/polymarket-ai-v2-esports (its own release
# path + symlink), isolated from MB/WB/ingestion which stay on /opt/polymarket-ai-v2.
# See EB-SPLINTER.md on branch eb/main for the splinter charter.
Description=Polymarket AI V2 — EsportsBot (splinter)
After=network.target postgresql.service redis.service
Wants=postgresql.service redis.service

[Service]
Type=simple
User=polymarket
Group=polymarket
WorkingDirectory=/opt/polymarket-ai-v2-esports
Environment=PYTHONUNBUFFERED=1
Environment="PYTHONWARNINGS=ignore::UserWarning:sklearn,ignore::FutureWarning:sklearn"
EnvironmentFile=/opt/pa2-shared/.env
EnvironmentFile=/opt/pa2-shared/.env.esports
ExecStart=/opt/polymarket-ai-v2-esports/venv/bin/python main.py
Restart=always
RestartSec=10
TimeoutStopSec=30
StartLimitIntervalSec=300
StartLimitBurst=5

# Security hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=false
ReadWritePaths=/opt/pa2-shared/data /opt/pa2-shared/saved_models /var/log/polymarket
PrivateTmp=true

# Resource limits
MemoryMax=2G
CPUQuota=80%

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=polymarket-esports

[Install]
WantedBy=multi-user.target
