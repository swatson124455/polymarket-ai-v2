# SECURITY TEMPLATE: Copy this to .env and fill in your secure values
# This file is safe to commit - it contains no real credentials

# ============================================
# AWS Lightsail (Dublin eu-west-1)
# ============================================
LIGHTSAIL_INSTANCE_NAME=LockePicks

# ============================================
# PostgreSQL Database (VPS Dublin)
# ============================================
DATABASE_URL=postgresql://polymarket:password@localhost:5432/polymarket

# ============================================
# Redis Configuration
# ============================================
# Optional; set REDIS_ENABLED=false to run without Redis
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# Optional: full URL overrides host/port/db (e.g. Redis Cloud, Upstash). Use redis://:password@host:6379/0 for auth
# REDIS_URL=redis://:password@host:6379/0
# Optional: password when not using REDIS_URL
# REDIS_PASSWORD=your_redis_password

# ============================================
# Polymarket API Endpoints
# ============================================
# Defaults are provided, usually no need to change
POLYMARKET_GAMMA_API=https://gamma-api.polymarket.com
POLYMARKET_CLOB_API=https://clob.polymarket.com
POLYMARKET_DATA_API=https://data-api.polymarket.com
POLYMARKET_WS=wss://ws-subscriptions-clob.polymarket.com/ws/market

# ============================================
# Wallet Configuration (OPTIONAL)
# ============================================
# SECURITY: Never share these values, keep them secure
# Leave empty for view-only mode
# PRIVATE_KEY=0x1234567890abcdef...
# WALLET_ADDRESS=0x1234...

# ============================================
# CLOB API (OPTIONAL)
# ============================================
# py-clob-client L2; if set, ExecutionEngine uses official client for orders
# Get from Polymarket: derive or create API key via py-clob-client or dashboard
# POLYGON_CHAIN_ID=137
# CLOB_API_KEY=your_api_key
# CLOB_SECRET=your_secret
# CLOB_PASSPHRASE=your_passphrase

# Direct connection — VPS IP handles geo-access (no VPN/proxy needed)

# ============================================
# External API Keys (OPTIONAL)
# ============================================
# The Graph Protocol (free tier: 100K queries/month at https://thegraph.com/studio)
# THE_GRAPH_API_KEY=your_graph_api_key

# LLM Probability Estimation (Claude or OpenAI)
# ANTHROPIC_API_KEY=your_anthropic_key
# OPENAI_API_KEY=your_openai_key

# Cross-Platform Arbitrage (Kalshi)
# KALSHI_API_KEY=your_kalshi_key
# KALSHI_EMAIL=your_kalshi_email

# News & Social Signals
# NEWSAPI_KEY=your_newsapi_key
# TWITTER_BEARER_TOKEN=your_twitter_token
# REDDIT_CLIENT_ID=your_reddit_id
# REDDIT_CLIENT_SECRET=your_reddit_secret

# Telegram Alerts
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id

# Oracle Monitor
# UMA_ORACLE_CONTRACT=0x...
# POLYGON_RPC_URL=https://polygon-rpc.com

# Secret Manager
# VAULT_PASSWORD=your_vault_password

# ============================================
# Blockchain RPC (OPTIONAL)
# ============================================
# POLYGON_RPC=https://polygon-mainnet.g.alchemy.com/v2/your-key
# QUICKNODE_HTTP=https://your-endpoint.quiknode.pro/your-key/
# ALCHEMY_HTTP=https://polygon-mainnet.g.alchemy.com/v2/your-key
# BLASTAPI_HTTP=https://polygon-mainnet.public.blastapi.io

# ============================================
# Scheduler Tuning (OPTIONAL)
# ============================================
# RETRAIN_INTERVAL_HOURS=6
# INGESTION_SCHEDULER_INTERVAL_MINUTES=5
# INGESTION_TOP_MARKETS_COUNT=500
# INGESTION_SCHEDULER_INITIAL_DELAY_SECONDS=30

# ============================================
# Risk Guardrails (OPTIONAL)
# ============================================
# RISK_MAX_POSITION_SIZE_USD=100
# RISK_MAX_TOTAL_EXPOSURE_USD=500
# RISK_MAX_POSITIONS_COUNT=20
# RISK_MAX_DAILY_LOSS_USD=50
# RISK_MAX_WEEKLY_LOSS_USD=150
# RISK_MAX_DRAWDOWN_PCT=20

# ============================================
# Paper Trading (default: enabled)
# ============================================
# SIMULATION_MODE=true
# PAPER_TRADING_CAPITAL=10000

# ============================================
# 2026 Alpha Roadmap: New Bots
# ============================================
# BOT_ENABLED_ORACLE=true
# BOT_ENABLED_SPORTS=true
# BOT_ENABLED_LLM_FORECASTER=true
# BOT_ENABLED_CROSS_PLATFORM_ARB=true

# ============================================
# Cross-Platform Arbitrage Adapters
# ============================================
# Coinbase Prediction Markets (event contracts, launched Jan 2026)
# COINBASE_PRED_API_KEY=your_coinbase_key
# COINBASE_PRED_API_SECRET=your_coinbase_secret

# ForecastEx via Interactive Brokers (requires IB Gateway running)
# FORECASTEX_IB_HOST=127.0.0.1
# FORECASTEX_IB_PORT=7497

# ============================================
# UMA Oracle Monitor
# ============================================
# UMA_OO_V3_POLYGON=0xOptimisticOracleV3Address
# UMA_PROPOSAL_MONITOR_ENABLED=true

# ============================================
# RLVR Model (LLMForecasterBot)
# ============================================
# RLVR_MODEL_PATH=./models/rlvr_polymarket
# RLVR_ENABLED=false

# ============================================
# AgenticRAG & Causal Inference (optional)
# ============================================
# AGENTIC_RAG_ENABLED=false
# CAUSAL_INFERENCE_ENABLED=false

# ============================================
# Sports Data (SportsBot)
# ============================================
# API_FOOTBALL_KEY=your_api_football_key
# SPORTS_API_PROVIDER=api-football

# ============================================
# Google Gemini (optional LLM backend)
# ============================================
# GOOGLE_API_KEY=your_google_api_key

# ============================================
# Alerting: Email (SMTP)
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your_app_password
# ALERT_EMAIL_FROM=you@gmail.com
# ALERT_EMAIL_TO=team@example.com,ops@example.com

# ============================================
# Alerting: SMS (Twilio - critical alerts only)
# ============================================
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_FROM_NUMBER=+15551234567
# ALERT_SMS_TO=+15559876543

# ============================================
# Audit framework (base_engine/audit/factory.py)
# ============================================
# SIGNAL_REQUIRED_BOTS: comma-separated list of bots whose ENTRY events MUST
# be preceded by a trade_signals row. Empty = no enforcement (default).
# Populate after verifying signal-write coverage per bot.
# S203: must include BOTH EsportsBot AND EsportsBotV2 before any
# ESPORTS_V2_DRY_RUN=false flip — otherwise v2's ENTRY events bypass
# rogue-trade detection. See S203_EB_ROUTING_AUDIT.md §3.3 + §5.3.
# SIGNAL_REQUIRED_BOTS=EsportsBot,EsportsBotV2

# SECURITY NOTES:
# 1. Never commit the real .env file to version control
# 2. Use a strong database password
# 3. Keep private keys secure and never share them
# 4. Consider using environment variables in production instead of .env files
