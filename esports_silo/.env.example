# esports_silo environment template.
# Real values live in your prod .env (/opt/pa2-shared/.env or local) — NEVER commit real keys.
# This file is a template of NAMES only.

# --- Siloed database (its OWN db, not the 15-bot prod db) ---
DATABASE_URL=postgresql://esports_silo:CHANGE_ME@localhost:5432/esports_silo

# --- Sharp-line aggregator (one aggregator, multiple books) ---
# Free tier is small (OddsPapi: 250 req/month) — the collector rate-limits itself.
ODDSPAPI_API_KEY=

# --- Match data / results ---
PANDASCORE_API_KEY=

# --- LoL patch + schedule (Riot personal keys EXPIRE every 24h) ---
RIOT_API_KEY=

# --- Polymarket public endpoints (no key; CLOB order-signing key derives from wallet) ---
POLYMARKET_GAMMA_API=https://gamma-api.polymarket.com
POLYMARKET_CLOB_API=https://clob.polymarket.com

# --- Which books the aggregator must return (verify coverage before trusting) ---
SHARP_BOOKS=pinnacle,circa,asian

# --- Games in scope ---
ESPORTS_GAMES=cs2,lol,dota2,valorant

# --- Safety: start HALTED / paper. Flip only after the skill gates pass. ---
SILO_ENTRY_HALT=true
